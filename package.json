{
  "name": "comms-gatekeeper",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node --trace-warnings --abort-on-uncaught-exception --unhandled-rejections=strict dist/index.js",
    "start:dev": "yarn build && yarn start",
    "start:dev:clean": "yarn migrate down 10 && yarn migrate up && yarn build && yarn start",
    "dev": "nodemon",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose --passWithNoTests",
    "lint:check": "eslint '**/*.{js,ts}'",
    "lint:fix": "eslint '**/*.{js,ts}' --fix",
    "format:check": "prettier --check '**/*.{js,ts}'",
    "format:fix": "prettier --write '**/*.{js,ts}'",
    "migrate": "node-pg-migrate --tsconfig ./tsconfig.json --migrations-dir ./src/migrations",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn nano-staged",
    "pre-push": "yarn typecheck && yarn test --no-coverage"
  },
  "nano-staged": {
    "*.{js,ts}": [
      "eslint",
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@dcl/eslint-config": "^2.2.1",
    "@types/node": "^20.7.1",
    "@well-known-components/test-helpers": "^1.5.8",
    "nano-staged": "0.8.0",
    "nodemon": "^3.0.1",
    "simple-git-hooks": "2.11.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "DEV=true ts-node ./src/index.ts"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "tabWidth": 2
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.787.0",
    "@dcl/analytics-component": "^1.0.3",
    "@dcl/core-commons": "^0.10.0",
    "@dcl/crypto": "^3.4.5",
    "@dcl/crypto-middleware": "^4.0.0",
    "@dcl/features-component": "^1.0.0",
    "@dcl/http-commons": "^2.0.0",
    "@dcl/http-server": "^2.0.1",
    "@dcl/http-tracer-component": "^2.0.0",
    "@dcl/memory-cache-component": "^2.4.2",
    "@dcl/metrics": "^1.0.1",
    "@dcl/schema-validator-component": "^1.0.0",
    "@dcl/schemas": "25.2.0",
    "@dcl/sns-component": "^3.0.0",
    "@dcl/traced-fetch-component": "^1.0.6",
    "@well-known-components/env-config-provider": "^1.1.1",
    "@well-known-components/interfaces": "^1.4.1",
    "@well-known-components/logger": "^3.1.2",
    "@well-known-components/pg-component": "^1.1.0",
    "@well-known-components/tracer-component": "^1.2.0",
    "cron": "^4.1.3",
    "dcl-catalyst-client": "^21.11.0",
    "livekit-server-sdk": "^2.12.0",
    "lru-cache": "^10.1.0",
    "sql-template-strings": "^2.2.2"
  }
}
